{
  "manifest_version": 3,
  "name": "Anti-Cuai",
  "version": "1.0.0",
  "description": "Cross-checks suspicious numbers and links with SemakMule.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Anti-Cuai",
    "default_icon": "icon-48.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}